<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="220dp">

        <androidx.media3.ui.PlayerView
            android:id="@+id/player_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>

        <WebView
            android:id="@+id/webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>

    </FrameLayout>

    <LinearLayout
        android:id="@+id/layout_m3u"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/et_m3u_url"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="URL da lista M3U"
            android:inputType="textUri"
            android:textColor="#ffffff"
            android:textColorHint="#888888"
            android:backgroundTint="#444444"
            android:paddingStart="8dp"
            android:singleLine="true"/>

        <Button
            android:id="@+id/btn_carregar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Carregar"
            android:textSize="12sp"
            android:backgroundTint="#e94560"/>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_playlist"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="6dp"
        android:background="#0f3460">

        <Button
            android:id="@+id/btn_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:text="Status"
            android:textSize="10sp"
            android:backgroundTint="#533483"/>

        <Button
            android:id="@+id/btn_modo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:text="WebView"
            android:textSize="10sp"
            android:backgroundTint="#16213e"/>

        <Button
            android:id="@+id/btn_reverter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:text="Reverter"
            android:textSize="10sp"
            android:backgroundTint="#e94560"/>

        <Button
            android:id="@+id/btn_mirror"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="3dp"
            android:text="Mirror"
            android:textSize="10sp"
            android:backgroundTint="#0f3460"/>

    </LinearLayout>

</LinearLayout>
