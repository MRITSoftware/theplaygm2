<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout da tela principal (activity_main.xml)

    Estrutura:
    LinearLayout vertical (ocupa a tela toda)
    ├── WebView          — exibe YouTube ou a tela de bloqueio (peso=1, expande)
    └── LinearLayout     — barra horizontal com os 3 botões de controle
        ├── Botão Status
        ├── Botão Reverter
        └── Botão Mirror
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e">

    <!--
        WebView: o componente central da demonstração
        É aqui que o YouTube carrega (APK desbloqueado)
        ou a tela de bloqueio HTML é exibida (APK bloqueado)

        layout_weight="1" = expande para preencher todo o espaço disponível
        acima dos botões
    -->
    <WebView
        android:id="@+id/webview_youtube"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!--
        Barra de botões na parte inferior da tela
        orientation="horizontal" = botões lado a lado
        background="#0f3460" = azul escuro para contraste com o WebView
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#0f3460">

        <!--
            Botão 1: Verificar status
            Chama btnVerificarStatus.setOnClickListener em MainActivity.kt
            layout_weight="1" = divide o espaço horizontal igualmente entre os 3 botões
        -->
        <Button
            android:id="@+id/btn_verificar_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="Status"
            android:textSize="11sp"
            android:backgroundTint="#e94560"/>

        <!--
            Botão 2: Reverter desbloqueio
            Chama reverterDesbloqueio() → limpa cache e aplica bloqueio
            Demonstra como desfazer o bypass (mitigação)
        -->
        <Button
            android:id="@+id/btn_reverter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="Reverter"
            android:textSize="11sp"
            android:backgroundTint="#16213e"/>

        <!--
            Botão 3: Ativar espelhamento de tela
            Chama ativarEspelhamentoTela() → exibe popup de permissão do Android
            Demonstra o segundo método de bypass do Fermata
        -->
        <Button
            android:id="@+id/btn_mirror"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="Mirror"
            android:textSize="11sp"
            android:backgroundTint="#533483"/>

    </LinearLayout>

</LinearLayout>
